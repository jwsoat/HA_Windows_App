<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HASS.Agent.UI.Controls.QuickActionCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Width="140"
        Height="160"
        CornerRadius="8"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        Padding="12">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Domain icon -->
            <FontIcon
                Grid.Row="0"
                x:Name="DomainIcon"
                FontSize="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Glyph="&#xE769;"/>

            <!-- Entity state badge (top-right corner) -->
            <Border
                Grid.Row="0"
                x:Name="StateBadge"
                Background="{ThemeResource AccentAAFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="6,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="StateText"
                    FontSize="10"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
            </Border>

            <!-- Display name -->
            <TextBlock
                Grid.Row="1"
                x:Name="NameText"
                TextWrapping="Wrap"
                MaxLines="2"
                TextTrimming="CharacterEllipsis"
                FontSize="12"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                Margin="0,8,0,2"/>

            <!-- Entity ID (small) -->
            <TextBlock
                Grid.Row="2"
                x:Name="EntityText"
                TextTrimming="CharacterEllipsis"
                FontSize="10"
                Opacity="0.6"
                HorizontalAlignment="Center"
                TextAlignment="Center"/>

        </Grid>
    </Border>
</UserControl>
