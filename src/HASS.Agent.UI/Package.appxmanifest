<?xml version="1.0" encoding="utf-8"?>
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
    xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap uap3 mp desktop rescap">

  <Identity
      Name="LAB02Research.HASSAgent"
      Publisher="CN=LAB02Research"
      Version="2.2.0.0" />

  <mp:PhoneIdentity PhoneProductId="3f9b81c2-7a4e-4a3a-9d5e-2c4e9b8f1d2a" PhonePublisherId="00000000-0000-0000-0000-000000000000"/>

  <Properties>
    <DisplayName>HASS.Agent</DisplayName>
    <PublisherDisplayName>LAB02 Research</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>Windows client for Home Assistant — sensors, commands, quick actions, and notifications.</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us"/>
  </Resources>

  <Applications>
    <Application Id="App" Executable="HASS.Agent.exe" EntryPoint="HASS.Agent.UI.App">

      <uap:VisualElements
          DisplayName="HASS.Agent"
          Description="Windows client for Home Assistant"
          BackgroundColor="transparent"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png"/>
        <uap:SplashScreen Image="Assets\SplashScreen.png" BackgroundColor="#1E1E1E"/>
      </uap:VisualElements>

      <Extensions>
        <!-- Auto-start at user login -->
        <desktop:Extension Category="windows.startupTask" Executable="HASS.Agent.exe" EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask TaskId="HassAgentStartup" Enabled="true" DisplayName="HASS.Agent"/>
        </desktop:Extension>
        <!-- TODO: add windows.toastNotificationActivation under uap3 once we have a COM activator class wired up
             (needed for HA → Windows notification click handling, but not for receiving toasts) -->
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust"/>
  </Capabilities>
</Package>
