<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HASS.Agent.UI.Views.Pages.HassApiSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="Home Assistant API" Style="{StaticResource TitleTextBlockStyle}"/>

            <TextBox x:Name="UriBox" Header="Home Assistant URL"
                     PlaceholderText="http://homeassistant.local:8123"/>

            <PasswordBox x:Name="TokenBox" Header="Long-Lived Access Token"/>

            <ToggleSwitch x:Name="AllowUntrustedToggle" Header="Allow Untrusted Certificates"/>

            <!-- Connection status -->
            <InfoBar x:Name="StatusBar" IsOpen="False" IsClosable="True"/>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Test Connection" Click="OnTest"/>
                <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave"/>
            </StackPanel>

            <!-- Connected info -->
            <Border x:Name="InfoPanel"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16"
                    Visibility="Collapsed">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="VersionText" Opacity="0.7"/>
                    <TextBlock x:Name="EntityCountText" Opacity="0.7"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
