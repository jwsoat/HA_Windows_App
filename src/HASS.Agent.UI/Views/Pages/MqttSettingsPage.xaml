<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HASS.Agent.UI.Views.Pages.MqttSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="MQTT Settings" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Enabled toggle -->
            <ToggleSwitch x:Name="EnabledToggle" Header="Enable MQTT" IsOn="True"/>

            <!-- Broker address -->
            <TextBox x:Name="AddressBox" Header="Broker Address" PlaceholderText="192.168.1.100"/>

            <!-- Port -->
            <NumberBox x:Name="PortBox" Header="Port" Minimum="1" Maximum="65535" Value="1883"
                       SpinButtonPlacementMode="Compact"/>

            <!-- TLS -->
            <ToggleSwitch x:Name="TlsToggle" Header="Use TLS"/>

            <ToggleSwitch x:Name="AllowUntrustedToggle"
                         Header="Allow Untrusted Certificates"/>

            <!-- Credentials -->
            <TextBox x:Name="UsernameBox" Header="Username" PlaceholderText="(optional)"/>
            <PasswordBox x:Name="PasswordBox" Header="Password" PlaceholderText="(optional)"/>

            <!-- Client ID -->
            <TextBox x:Name="ClientIdBox" Header="Client ID" PlaceholderText="Auto-generated if empty"/>

            <!-- Discovery prefix -->
            <TextBox x:Name="DiscoveryPrefixBox" Header="Discovery Prefix" PlaceholderText="homeassistant"/>

            <!-- Options -->
            <ToggleSwitch x:Name="RetainFlagToggle" Header="Use Retain Flag"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button Content="Test Connection" Click="OnTestConnection"/>
                <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave"/>
            </StackPanel>

            <!-- Test result -->
            <InfoBar x:Name="TestResultBar" IsOpen="False" IsClosable="True"/>

        </StackPanel>
    </ScrollViewer>
</Page>
