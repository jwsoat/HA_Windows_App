<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HASS.Agent.UI.Views.Pages.QuickActionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:HASS.Agent.Core.Models.Internal">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + toolbar -->
        <StackPanel Grid.Row="0" Margin="24,24,24,12" Spacing="12">
            <TextBlock Text="Quick Actions" Style="{StaticResource TitleTextBlockStyle}"/>

            <CommandBar DefaultLabelPosition="Right" HorizontalAlignment="Left">
                <AppBarButton Icon="Add" Label="Add" Click="OnAdd"/>
                <AppBarButton x:Name="EditButton" Icon="Edit" Label="Edit"
                              IsEnabled="False" Click="OnEdit"/>
                <AppBarButton x:Name="DeleteButton" Icon="Delete" Label="Delete"
                              IsEnabled="False" Click="OnDelete"/>
                <AppBarSeparator/>
                <AppBarButton Icon="Up" Label="Move Up"
                              x:Name="MoveUpButton" IsEnabled="False" Click="OnMoveUp"/>
                <AppBarButton Icon="Down" Label="Move Down"
                              x:Name="MoveDownButton" IsEnabled="False" Click="OnMoveDown"/>
            </CommandBar>
        </StackPanel>

        <!-- List -->
        <ListView
            x:Name="ActionsList"
            Grid.Row="1"
            Margin="24,0,24,0"
            SelectionChanged="OnSelectionChanged"
            ItemsSource="{x:Bind Actions}"
            CanReorderItems="True"
            AllowDrop="True"
            ReorderMode="Enabled">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:QuickAction">
                    <Grid ColumnSpacing="12" Padding="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Entity}" Opacity="0.6" FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="{x:Bind GroupName}" Opacity="0.6" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2" Text="{x:Bind Action}" Opacity="0.6" VerticalAlignment="Center"/>

                        <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                     MinWidth="0" OnContent="" OffContent=""
                                     VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom info bar -->
        <TextBlock Grid.Row="2"
                   x:Name="CountText"
                   Margin="24,8,24,16"
                   Opacity="0.6"
                   FontSize="12"/>
    </Grid>
</Page>
