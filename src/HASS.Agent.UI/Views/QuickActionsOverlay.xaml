<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HASS.Agent.UI.Views.QuickActionsOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HASS.Agent.UI.ViewModels"
    xmlns:controls="using:HASS.Agent.UI.Controls"
    xmlns:core="using:HASS.Agent.Core.Models.Internal">

    <Grid x:Name="RootGrid"
          Background="Transparent"
          Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search box -->
        <TextBox
            Grid.Row="0"
            x:Name="SearchBox"
            PlaceholderText="Search actions..."
            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Margin="0,0,0,12"
            CornerRadius="8"
            FontSize="15"
            Height="44"/>

        <!-- Group filter pills -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollMode="Auto"
            HorizontalScrollBarVisibility="Hidden"
            VerticalScrollMode="Disabled"
            Margin="0,0,0,16">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Groups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:GroupPill">
                        <ToggleButton
                            Content="{x:Bind Name}"
                            IsChecked="{x:Bind IsActive, Mode=OneWay}"
                            Command="{Binding ElementName=ActionsGrid, Path=Tag}"
                            CommandParameter="{x:Bind Name}"
                            CornerRadius="16"
                            Padding="16,6"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Action cards grid -->
        <GridView
            x:Name="ActionsGrid"
            Grid.Row="2"
            Tag="{x:Bind ViewModel.SelectGroupCommand}"
            ItemsSource="{x:Bind ViewModel.FilteredActions}"
            SelectionMode="None"
            IsItemClickEnabled="True"
            ItemClick="OnCardClicked"
            HorizontalAlignment="Stretch">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        Orientation="Horizontal"
                        MaximumRowsOrColumns="6"
                        ItemWidth="152"
                        ItemHeight="172"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="core:QuickAction">
                    <controls:QuickActionCard Action="{x:Bind}"/>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Loading overlay -->
        <ProgressRing
            Grid.Row="2"
            IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="48" Height="48"/>

    </Grid>
</Window>
