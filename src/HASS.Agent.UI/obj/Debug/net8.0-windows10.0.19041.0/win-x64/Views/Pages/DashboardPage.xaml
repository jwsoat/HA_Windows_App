<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HASS.Agent.UI.Views.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24">

            <TextBlock Text="Dashboard" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- MQTT status card -->
            <InfoBar x:ConnectionId='2'
                x:Name="MqttInfoBar"
                IsOpen="True"
                IsClosable="False"
                Title="MQTT"
                Message="Connecting..."
                Severity="Informational"/>

            <!-- HA API status card -->
            <InfoBar x:ConnectionId='3'
                x:Name="HassApiInfoBar"
                IsOpen="True"
                IsClosable="False"
                Title="Home Assistant API"
                Message="Connecting..."
                Severity="Informational"/>

            <!-- Quick actions summary -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Quick Actions" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock x:ConnectionId='5' x:Name="QuickActionsCountText" Opacity="0.7"/>
                    <Button x:ConnectionId='6' Content="Open Overlay"                      />
                </StackPanel>
            </Border>

            <!-- Update notification (shown when update available) -->
            <InfoBar x:ConnectionId='4'
                x:Name="UpdateInfoBar"
                IsOpen="False"
                IsClosable="True"
                Title="Update Available"
                Severity="Success">
                <InfoBar.ActionButton>
                    <HyperlinkButton Content="View Release"/>
                </InfoBar.ActionButton>
            </InfoBar>

        </StackPanel>
    </ScrollViewer>
</Page>

