<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HASS.Agent.UI.Views.Pages.MqttSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="MQTT Settings" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Enabled toggle -->
            <ToggleSwitch x:ConnectionId='2' x:Name="EnabledToggle" Header="Enable MQTT" IsOn="True"/>

            <!-- Broker address -->
            <TextBox x:ConnectionId='3' x:Name="AddressBox" Header="Broker Address" PlaceholderText="192.168.1.100"/>

            <!-- Port -->
            <NumberBox x:ConnectionId='4' x:Name="PortBox" Header="Port" Minimum="1" Maximum="65535" Value="1883"
                       SpinButtonPlacementMode="Compact"/>

            <!-- TLS -->
            <ToggleSwitch x:ConnectionId='5' x:Name="TlsToggle" Header="Use TLS"/>

            <ToggleSwitch x:ConnectionId='6' x:Name="AllowUntrustedToggle"
                         Header="Allow Untrusted Certificates"/>

            <!-- Credentials -->
            <TextBox x:ConnectionId='7' x:Name="UsernameBox" Header="Username" PlaceholderText="(optional)"/>
            <PasswordBox x:ConnectionId='8' x:Name="PasswordBox" Header="Password" PlaceholderText="(optional)"/>

            <!-- Client ID -->
            <TextBox x:ConnectionId='9' x:Name="ClientIdBox" Header="Client ID" PlaceholderText="Auto-generated if empty"/>

            <!-- Discovery prefix -->
            <TextBox x:ConnectionId='10' x:Name="DiscoveryPrefixBox" Header="Discovery Prefix" PlaceholderText="homeassistant"/>

            <!-- Options -->
            <ToggleSwitch x:ConnectionId='11' x:Name="RetainFlagToggle" Header="Use Retain Flag"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <Button x:ConnectionId='13' Content="Test Connection"                         />
                <Button x:ConnectionId='14' Content="Save" Style="{StaticResource AccentButtonStyle}"               />
            </StackPanel>

            <!-- Test result -->
            <InfoBar x:ConnectionId='12' x:Name="TestResultBar" IsOpen="False" IsClosable="True"/>

        </StackPanel>
    </ScrollViewer>
</Page>

