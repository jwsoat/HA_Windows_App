<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="HASS.Agent.UI.Views.Pages.QuickActionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:HASS.Agent.Core.Models.Internal">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + toolbar -->
        <StackPanel Grid.Row="0" Margin="24,24,24,12" Spacing="12">
            <TextBlock Text="Quick Actions" Style="{StaticResource TitleTextBlockStyle}"/>

            <CommandBar DefaultLabelPosition="Right" HorizontalAlignment="Left">
                <AppBarButton x:ConnectionId='11' Icon="Add" Label="Add"              />
                <AppBarButton x:ConnectionId='12' x:Name="EditButton" Icon="Edit" Label="Edit"
                              IsEnabled="False"               />
                <AppBarButton x:ConnectionId='13' x:Name="DeleteButton" Icon="Delete" Label="Delete"
                              IsEnabled="False"                 />
                <AppBarSeparator/>
                <AppBarButton x:ConnectionId='14' Icon="Up" Label="Move Up"
                              x:Name="MoveUpButton" IsEnabled="False"                 />
                <AppBarButton x:ConnectionId='15' Icon="Down" Label="Move Down"
                              x:Name="MoveDownButton" IsEnabled="False"                   />
            </CommandBar>
        </StackPanel>

        <!-- List -->
        <ListView x:ConnectionId='2'
            x:Name="ActionsList"
            Grid.Row="1"
            Margin="24,0,24,0"
                                                 
                                          
            CanReorderItems="True"
            AllowDrop="True"
            ReorderMode="Enabled">
            <ListView.ItemTemplate>
                <DataTemplate                              >
                    <Grid x:ConnectionId='5' ColumnSpacing="12" Padding="8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:ConnectionId='9'                             FontWeight="SemiBold"/>
                            <TextBlock x:ConnectionId='10'                        Opacity="0.6" FontSize="12"/>
                        </StackPanel>

                        <TextBlock x:ConnectionId='6' Grid.Column="1"                           Opacity="0.6" VerticalAlignment="Center"/>

                        <TextBlock x:ConnectionId='7' Grid.Column="2"                        Opacity="0.6" VerticalAlignment="Center"/>

                        <ToggleSwitch x:ConnectionId='8' Grid.Column="3"                                       
                                     MinWidth="0" OnContent="" OffContent=""
                                     VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Bottom info bar -->
        <TextBlock x:ConnectionId='3' Grid.Row="2"
                   x:Name="CountText"
                   Margin="24,8,24,16"
                   Opacity="0.6"
                   FontSize="12"/>
    </Grid>
</Page>

