<?xml version="1.0" encoding="utf-8"?>
<Window x:ConnectionId='1'
    x:Class="HASS.Agent.UI.Views.QuickActionsOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HASS.Agent.UI.ViewModels"
    xmlns:controls="using:HASS.Agent.UI.Controls"
    xmlns:core="using:HASS.Agent.Core.Models.Internal">

    <Grid x:ConnectionId='2' x:Name="RootGrid"
          Background="Transparent"
          Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Search box -->
        <TextBox x:ConnectionId='3'
            Grid.Row="0"
            x:Name="SearchBox"
            PlaceholderText="Search actions..."
                                                                                                  
            Margin="0,0,0,12"
            CornerRadius="8"
            FontSize="15"
            Height="44"/>

        <!-- Group filter pills -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollMode="Auto"
            HorizontalScrollBarVisibility="Hidden"
            VerticalScrollMode="Disabled"
            Margin="0,0,0,16">
            <ItemsControl x:ConnectionId='8'                                        >
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate                          >
                        <ToggleButton x:ConnectionId='10'
                                                   
                                                                      
                            Command="{Binding ElementName=ActionsGrid, Path=Tag}"
                                                            
                            CornerRadius="16"
                            Padding="16,6"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Action cards grid -->
        <GridView x:ConnectionId='4'
            x:Name="ActionsGrid"
            Grid.Row="2"
                                                       
                                                            
            SelectionMode="None"
            IsItemClickEnabled="True"
                                     
            HorizontalAlignment="Stretch">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        Orientation="Horizontal"
                        MaximumRowsOrColumns="6"
                        ItemWidth="152"
                        ItemHeight="172"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate                              >
                    <controls:QuickActionCard x:ConnectionId='7'                  />
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- Loading overlay -->
        <ProgressRing x:ConnectionId='5'
            Grid.Row="2"
                                                             
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="48" Height="48"/>

    </Grid>
</Window>

