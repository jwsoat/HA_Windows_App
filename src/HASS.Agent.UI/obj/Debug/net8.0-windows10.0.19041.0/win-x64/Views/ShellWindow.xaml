<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HASS.Agent.UI.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HASS.Agent Settings">

    <Grid>
        <NavigationView x:ConnectionId='2'
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
                                                    >

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="quickactions" Content="Quick Actions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE785;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="sensors" Content="Sensors">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9F3;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="commands" Content="Commands">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE756;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Tag="mqtt" Content="MQTT">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D4;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="hassapi" Content="HA API">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="notifications" Content="Notifications">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA8F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="about" Content="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:ConnectionId='3' x:Name="ContentFrame"/>

        </NavigationView>
    </Grid>
</Window>

